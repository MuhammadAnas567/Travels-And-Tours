generator client {
  provider      = "prisma-client-js"
  // native = local; rhel-openssl-3.0.x = Vercel / AWS Linux
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENT
  ADMIN
}

enum TourStatus {
  ACTIVE
  DRAFT
}

enum TourCategory {
  ADVENTURE
  FAMILY
  HONEYMOON
  CULTURAL
  BEACH
  WILDLIFE
  LUXURY
  BUDGET
  UMRAH
  HERITAGE
}

enum TourAudience {
  OUTBOUND
  INBOUND
  BOTH
}

enum BookingStatus {
  PENDING
  PENDING_VERIFICATION
  CONFIRMED
  CANCELLED
  COMPLETED
  DEPOSIT_PAID
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
}

enum VisaInquiryStatus {
  NEW
  IN_REVIEW
  DOCS_NEEDED
  SUBMITTED
  APPROVED
  REJECTED
}

enum QuoteStatus {
  NEW
  QUOTED
  CONVERTED
  CLOSED
}

enum CouponType {
  PERCENT
  FIXED
}

enum Currency {
  PKR
  USD
  EUR
  GBP
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  hashedPassword   String?
  image            String?
  role             UserRole  @default(USER)
  preferredCurrency Currency @default(USD)
  preferredLocale  String    @default("en")
  /** Hotel wishlist items (JSON array) — synced from client localStorage on login */
  wishlist         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  bookings       Booking[]
  reviews        Review[]
  visaInquiries  VisaInquiry[]
  quoteRequests  QuoteRequest[]
  assignedQuotes QuoteRequest[] @relation("AssignedQuotes")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Tour {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  slug           String       @unique
  title          String
  description    String
  location       String
  country        String
  category       TourCategory
  audience       TourAudience @default(BOTH)
  durationDays   Int
  price          Float
  discountPrice  Float?
  baseCurrency   Currency     @default(USD)
  images         String[]
  itinerary      Json
  included       String[]
  excluded       String[]
  maxGroupSize   Int
  status         TourStatus   @default(DRAFT)
  avgRating      Float        @default(0)
  isFeatured     Boolean      @default(false)
  allowDeposit   Boolean      @default(false)
  depositPercent Int          @default(30)
  visaCountry    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  availableDates TourDate[]
  bookings       Booking[]
  reviews        Review[]
}

model TourDate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tourId      String   @db.ObjectId
  startDate   DateTime
  endDate     DateTime
  seatsTotal  Int
  seatsBooked Int      @default(0)

  tour     Tour      @relation(fields: [tourId], references: [id])
  bookings Booking[]
}

model Booking {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  userId            String        @db.ObjectId
  tourId            String        @db.ObjectId
  tourDateId        String        @db.ObjectId
  adults            Int
  children          Int           @default(0)
  totalPrice        Float
  currency          Currency      @default(USD)
  status            BookingStatus @default(PENDING)
  paymentMethod     PaymentMethod @default(STRIPE)
  paymentProofUrl   String?
  paymentIntentId   String?
  stripeSessionId   String?
  bookingReference  String?       @unique
  couponCode        String?
  depositAmount     Float?
  balanceDue        Float?
  balanceDueDate    DateTime?
  verifiedAt        DateTime?
  verifiedBy        String?
  travelerInfo      Json
  specialRequests   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  tour     Tour     @relation(fields: [tourId], references: [id])
  tourDate TourDate @relation(fields: [tourDateId], references: [id])
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tourId    String   @db.ObjectId
  rating    Int
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tour Tour @relation(fields: [tourId], references: [id])

  @@unique([userId, tourId])
}

model VisaInfo {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  country           String   @unique
  countrySlug       String   @unique
  flagEmoji         String?
  visaType          String
  requirements      String
  documentChecklist String[]
  processingTime    String
  govFee            Float
  serviceFee        Float
  successNotes      String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inquiries VisaInquiry[]
}

model VisaInquiry {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  userId      String            @db.ObjectId
  visaInfoId  String            @db.ObjectId
  country     String
  travelDate  DateTime?
  notes       String?
  status      VisaInquiryStatus @default(NEW)
  adminNotes  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  visaInfo VisaInfo @relation(fields: [visaInfoId], references: [id])
}

model QuoteRequest {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  userId             String?     @db.ObjectId
  assignedAgentId    String?     @db.ObjectId
  /** TRIP | HOTEL | FLIGHT | CAR | VISA */
  kind               String      @default("TRIP")
  name               String
  email              String
  phone              String?
  destinations       String[]
  startDate          DateTime?
  endDate            DateTime?
  adults             Int         @default(2)
  children           Int         @default(0)
  budget             Float?
  budgetCurrency     Currency    @default(USD)
  preferences        String?
  status             QuoteStatus @default(NEW)
  adminQuotePrice    Float?
  adminNotes         String?
  convertedBookingId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user          User? @relation(fields: [userId], references: [id])
  assignedAgent User? @relation("AssignedQuotes", fields: [assignedAgentId], references: [id])
}

model CrmNote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  quoteId   String   @db.ObjectId
  authorId  String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())
}

model Coupon {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  code            String     @unique
  type            CouponType
  value           Float
  minSpend        Float?
  usageLimit      Int?
  usageCount      Int        @default(0)
  perUserLimit    Int        @default(1)
  validFrom       DateTime
  validTo         DateTime
  applicableTours String[]
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model BlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  category    String
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  key             String   @unique
  value           Json
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId   String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
}

model FxRate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  base      Currency @default(USD)
  rates     Json
  fetchedAt DateTime @default(now())
}
