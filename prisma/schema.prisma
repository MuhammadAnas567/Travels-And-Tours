generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TourStatus {
  ACTIVE
  DRAFT
}

enum TourCategory {
  ADVENTURE
  FAMILY
  HONEYMOON
  CULTURAL
  BEACH
  WILDLIFE
  LUXURY
  BUDGET
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  bookings Booking[]
  reviews  Review[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Tour {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  slug          String       @unique
  title         String
  description   String
  location      String
  country       String
  category      TourCategory
  durationDays  Int
  price         Float
  discountPrice Float?
  images        String[]
  itinerary     Json
  included      String[]
  excluded      String[]
  maxGroupSize  Int
  status        TourStatus   @default(DRAFT)
  avgRating     Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  availableDates TourDate[]
  bookings       Booking[]
  reviews        Review[]
}

model TourDate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tourId      String   @db.ObjectId
  startDate   DateTime
  endDate     DateTime
  seatsTotal  Int
  seatsBooked Int      @default(0)

  tour     Tour      @relation(fields: [tourId], references: [id])
  bookings Booking[]
}

model Booking {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  userId          String        @db.ObjectId
  tourId          String        @db.ObjectId
  tourDateId      String        @db.ObjectId
  adults          Int
  children        Int           @default(0)
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  paymentIntentId String?
  stripeSessionId String?
  travelerInfo    Json
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  tour     Tour     @relation(fields: [tourId], references: [id])
  tourDate TourDate @relation(fields: [tourDateId], references: [id])
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tourId    String   @db.ObjectId
  rating    Int
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tour Tour @relation(fields: [tourId], references: [id])

  @@unique([userId, tourId])
}
